# Pin registry ke npm resmi untuk menghindari error EALLOWREMOTE / "Refusing to
# fetch ... http://mirrors.tencentyun.com" pada VPS dengan mirror pihak ketiga.
registry=https://registry.npmjs.org/

# Tampilkan output build modul native (sqlite3, bcrypt) secara langsung.
ignore-scripts=false
foreground-scripts=true

fund=false
audit=false

# CATATAN PENTING: npm versi baru memblokir install-scripts lewat gerbang
# "allowScripts" (ignore-scripts=false saja TIDAK cukup). Persetujuan build
# modul native dilakukan OTOMATIS di install.sh dengan perintah:
#   npm install-scripts approve <pkg>   lalu   npm rebuild --foreground-scripts
