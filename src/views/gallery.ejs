<% layout('layout') -%>
<%#
  src/views/gallery.ejs
  FILE BARU: view gallery hilang saat porting dari StreamFire -> "Failed to lookup view gallery".
  Dibangun ulang sesuai data dari route GET /gallery (userRoutes.js:173):
    title, active, user, videos, folders, currentFolder, currentFolderId
  Memakai endpoint API yang sudah ada:
    POST   /api/media-folders            { name }
    PUT    /api/media-folders/:id         { name }
    DELETE /api/media-folders/:id
    PUT    /api/videos/:id/folder         { folderId }
    DELETE /api/videos/:id
  Catatan: aksi memakai data-* attribute + event listener (bukan inline onclick)
  supaya aman dari masalah escaping tanda kutip pada nama file/folder.
-%>
<div class="max-w-7xl mx-auto">
  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Video Gallery</h1>
      <div class="text-sm text-gray-400 mt-1">
        <a href="/gallery" class="hover:text-white transition-colors">Root</a>
        <% if (currentFolder) { %>
          <span class="mx-1">/</span>
          <span class="text-white"><%= currentFolder.name %></span>
        <% } %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <% if (!currentFolderId) { %>
      <button id="btnNewFolder" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-dark-700 hover:bg-dark-600 text-sm transition-colors">
        <i class="ti ti-folder-plus"></i> New Folder
      </button>
      <% } %>
      <a href="/dashboard" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-primary hover:opacity-90 text-sm transition-colors">
        <i class="ti ti-upload"></i> Upload Video
      </a>
    </div>
  </div>

  <!-- Folders (hanya di root) -->
  <% if (!currentFolderId && folders && folders.length > 0) { %>
  <div class="mb-8">
    <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-3">Folders</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <% folders.forEach(function(folder) { %>
      <div class="group relative bg-dark-800 border border-gray-700 rounded-xl p-4 hover:border-primary transition-colors">
        <a href="/gallery?folder=<%= encodeURIComponent(folder.id) %>" class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-dark-700 flex items-center justify-center flex-shrink-0">
            <i class="ti ti-folder text-xl text-primary"></i>
          </div>
          <div class="min-w-0">
            <div class="font-medium truncate"><%= folder.name %></div>
            <div class="text-xs text-gray-400"><%= folder.item_count || 0 %> item</div>
          </div>
        </a>
        <div class="absolute top-2 right-2 hidden group-hover:flex items-center gap-1">
          <button class="js-rename-folder p-1.5 rounded-lg hover:bg-dark-700 text-gray-400 hover:text-white" data-id="<%= folder.id %>" data-name="<%= folder.name %>" title="Rename">
            <i class="ti ti-pencil text-sm"></i>
          </button>
          <button class="js-delete-folder p-1.5 rounded-lg hover:bg-dark-700 text-gray-400 hover:text-red-400" data-id="<%= folder.id %>" data-name="<%= folder.name %>" title="Delete">
            <i class="ti ti-trash text-sm"></i>
          </button>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Videos -->
  <div>
    <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-3">Videos</h2>
    <% if (videos && videos.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      <% videos.forEach(function(video) { %>
      <div class="group bg-dark-800 border border-gray-700 rounded-xl overflow-hidden hover:border-primary transition-colors">
        <div class="relative aspect-video bg-dark-700 overflow-hidden">
          <% if (video.thumbnail_path) { %>
            <img src="<%= video.thumbnail_path %>" class="w-full h-full object-cover" onerror="this.src='/images/default-thumbnail.jpg'">
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center">
              <i class="ti ti-video text-3xl text-gray-500"></i>
            </div>
          <% } %>
          <% if (video.duration) { %>
          <span class="absolute bottom-2 right-2 bg-black/70 text-white text-xs px-1.5 py-0.5 rounded"><%= helpers.formatDuration(video.duration) %></span>
          <% } %>
        </div>
        <div class="p-3">
          <div class="font-medium truncate" title="<%= video.title %>"><%= video.title %></div>
          <div class="text-xs text-gray-400 mt-1 flex items-center gap-2">
            <% if (video.resolution) { %><span><%= video.resolution %></span><% } %>
            <span data-filesize="<%= video.file_size || 0 %>"></span>
          </div>
          <div class="flex items-center justify-end gap-1 mt-2">
            <button class="js-move-video p-1.5 rounded-lg hover:bg-dark-700 text-gray-400 hover:text-white" data-id="<%= video.id %>" title="Move to folder">
              <i class="ti ti-folder-symlink text-sm"></i>
            </button>
            <button class="js-delete-video p-1.5 rounded-lg hover:bg-dark-700 text-gray-400 hover:text-red-400" data-id="<%= video.id %>" data-title="<%= video.title %>" title="Delete">
              <i class="ti ti-trash text-sm"></i>
            </button>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <i class="ti ti-photo-off text-4xl text-gray-600 mb-3"></i>
      <p class="text-gray-400">Belum ada video di sini.</p>
      <a href="/dashboard" class="mt-3 text-primary text-sm hover:underline">Upload video di Dashboard</a>
    </div>
    <% } %>
  </div>
</div>

<!-- Move-to-folder modal -->
<div id="moveModal" class="fixed inset-0 bg-black/60 z-50 hidden items-center justify-center p-4">
  <div class="bg-dark-800 border border-gray-700 rounded-xl w-full max-w-sm p-5">
    <h3 class="font-semibold mb-3">Move video to folder</h3>
    <select id="moveFolderSelect" class="w-full bg-dark-700 border border-gray-700 rounded-lg px-3 py-2 text-sm mb-4">
      <option value="">Root (no folder)</option>
      <% (folders || []).forEach(function(folder) { %>
      <option value="<%= folder.id %>"><%= folder.name %></option>
      <% }); %>
    </select>
    <div class="flex justify-end gap-2">
      <button id="moveCancel" class="px-4 py-2 rounded-lg bg-dark-700 hover:bg-dark-600 text-sm">Cancel</button>
      <button id="moveConfirm" class="px-4 py-2 rounded-lg bg-primary hover:opacity-90 text-sm">Move</button>
    </div>
  </div>
</div>

<script>
  (function () {
    // Format ukuran file di client
    document.querySelectorAll('[data-filesize]').forEach(function (el) {
      var b = parseInt(el.getAttribute('data-filesize'), 10);
      if (!b || isNaN(b)) { el.textContent = ''; return; }
      var units = ['B', 'KB', 'MB', 'GB', 'TB'];
      var i = Math.floor(Math.log(b) / Math.log(1024));
      el.textContent = (b / Math.pow(1024, i)).toFixed(1) + ' ' + units[i];
    });

    async function apiCall(url, method, body) {
      var opts = { method: method, headers: { 'Content-Type': 'application/json' } };
      if (body) opts.body = JSON.stringify(body);
      var res = await fetch(url, opts);
      var data = {};
      try { data = await res.json(); } catch (e) {}
      if (!res.ok || data.success === false) {
        throw new Error((data && data.error) || ('Request failed (' + res.status + ')'));
      }
      return data;
    }

    var newFolderBtn = document.getElementById('btnNewFolder');
    if (newFolderBtn) {
      newFolderBtn.addEventListener('click', async function () {
        var name = prompt('Nama folder baru:');
        if (!name) return;
        try { await apiCall('/api/media-folders', 'POST', { name: name.trim() }); location.reload(); }
        catch (e) { alert(e.message); }
      });
    }

    document.querySelectorAll('.js-rename-folder').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        var id = btn.getAttribute('data-id');
        var currentName = btn.getAttribute('data-name') || '';
        var name = prompt('Ganti nama folder:', currentName);
        if (!name || name.trim() === currentName) return;
        try { await apiCall('/api/media-folders/' + id, 'PUT', { name: name.trim() }); location.reload(); }
        catch (e) { alert(e.message); }
      });
    });

    document.querySelectorAll('.js-delete-folder').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        var id = btn.getAttribute('data-id');
        var name = btn.getAttribute('data-name') || '';
        if (!confirm('Hapus folder "' + name + '" beserta semua video di dalamnya?')) return;
        try { await apiCall('/api/media-folders/' + id, 'DELETE'); location.reload(); }
        catch (e) { alert(e.message); }
      });
    });

    document.querySelectorAll('.js-delete-video').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        var id = btn.getAttribute('data-id');
        var title = btn.getAttribute('data-title') || '';
        if (!confirm('Hapus video "' + title + '"?')) return;
        try { await apiCall('/api/videos/' + id, 'DELETE'); location.reload(); }
        catch (e) { alert(e.message); }
      });
    });

    // Move modal
    var moveVideoId = null;
    var moveModal = document.getElementById('moveModal');
    function openMove(id) { moveVideoId = id; moveModal.classList.remove('hidden'); moveModal.classList.add('flex'); }
    function closeMove() { moveVideoId = null; moveModal.classList.add('hidden'); moveModal.classList.remove('flex'); }

    document.querySelectorAll('.js-move-video').forEach(function (btn) {
      btn.addEventListener('click', function () { openMove(btn.getAttribute('data-id')); });
    });
    document.getElementById('moveCancel').addEventListener('click', closeMove);
    document.getElementById('moveConfirm').addEventListener('click', async function () {
      if (!moveVideoId) return;
      var folderId = document.getElementById('moveFolderSelect').value;
      try { await apiCall('/api/videos/' + moveVideoId + '/folder', 'PUT', { folderId: folderId }); location.reload(); }
      catch (e) { alert(e.message); }
    });
    moveModal.addEventListener('click', function (e) { if (e.target === moveModal) closeMove(); });
  })();
</script>
